# PM Digital Employee - Environment Configuration Template
# 项目经理数字员工系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 注意：所有敏感信息禁止硬编码，必须从环境变量或密钥管理服务读取

# ============================================
# 应用基础配置
# ============================================

# 应用名称
APP_NAME=PM Digital Employee

# 运行环境: development | testing | production
APP_ENV=development

# 调试模式（生产环境必须设为false）
APP_DEBUG=false

# 应用密钥（用于签名、加密等，生产环境必须使用强随机密钥）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=change_this_to_secure_secret_key_in_production

# 应用主机绑定地址
APP_HOST=0.0.0.0

# 应用端口
APP_PORT=8000

# Uvicorn工作进程数（生产环境建议2-4倍CPU核心数）
APP_WORKERS=4

# API版本号
API_VERSION=v1

# ============================================
# PostgreSQL数据库配置
# ============================================

# 数据库用户名
POSTGRES_USER=pm_user

# 数据库密码（生产环境必须使用强密码）
POSTGRES_PASSWORD=pm_password_change_in_production

# 数据库名称
POSTGRES_DB=pm_digital_employee

# 数据库主机地址
POSTGRES_HOST=localhost

# 数据库端口
POSTGRES_PORT=5432

# 完整数据库连接URL（异步驱动）
DATABASE_URL=postgresql+asyncpg://pm_user:pm_password_change_in_production@localhost:5432/pm_digital_employee

# 完整数据库连接URL（同步驱动，用于Alembic迁移）
DATABASE_URL_SYNC=postgresql://pm_user:pm_password_change_in_production@localhost:5432/pm_digital_employee

# 数据库连接池大小
DATABASE_POOL_SIZE=20

# 数据库连接池溢出数
DATABASE_MAX_OVERFLOW=10

# 数据库连接池回收时间（秒）
DATABASE_POOL_RECYCLE=3600

# 数据库SSL模式（生产环境建议require）
DATABASE_SSL_MODE=prefer

# ============================================
# Redis缓存配置
# ============================================

# Redis主机地址
REDIS_HOST=localhost

# Redis端口
REDIS_PORT=6379

# Redis密码（生产环境必须设置密码）
REDIS_PASSWORD=pm_redis_password_change_in_production

# Redis数据库索引（默认为0）
REDIS_DB=0

# 完整Redis连接URL
REDIS_URL=redis://:pm_redis_password_change_in_production@localhost:6379/0

# Redis连接池大小
REDIS_POOL_SIZE=10

# Redis缓存默认过期时间（秒）
REDIS_DEFAULT_TTL=3600

# ============================================
# RabbitMQ消息队列配置
# ============================================

# RabbitMQ用户名
RABBITMQ_USER=pm_rabbitmq

# RabbitMQ密码（生产环境必须使用强密码）
RABBITMQ_PASSWORD=pm_rabbitmq_password_change_in_production

# RabbitMQ虚拟主机
RABBITMQ_VHOST=pm_vhost

# RabbitMQ主机地址
RABBITMQ_HOST=localhost

# RabbitMQ端口（AMQP）
RABBITMQ_PORT=5672

# RabbitMQ管理端口
RABBITMQ_MGMT_PORT=15672

# ============================================
# Celery异步任务配置
# ============================================

# Celery Broker URL
CELERY_BROKER_URL=pyamqp://pm_rabbitmq:pm_rabbitmq_password_change_in_production@localhost:5672/pm_vhost

# Celery结果后端URL
CELERY_RESULT_BACKEND=redis://:pm_redis_password_change_in_production@localhost:6379/1

# Celery Worker并发数
CELERY_WORKER_CONCURRENCY=4

# Celery任务执行硬超时（秒）
CELERY_TASK_TIME_LIMIT=3600

# Celery任务执行软超时（秒）
CELERY_TASK_SOFT_TIME_LIMIT=3300

# Celery Beat调度间隔（秒）
CELERY_BEAT_MAX_INTERVAL=60

# ============================================
# 飞书开放平台配置
# ============================================

# 飞书应用ID（App ID）
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx

# 飞书应用密钥（App Secret）
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书事件加密密钥（Encrypt Key，用于事件加密）
LARK_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书事件验证Token（Verification Token）
LARK_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书API域名
LARK_API_DOMAIN=https://open.feishu.cn

# 飞书Tenant Token缓存时间（秒）
LARK_TOKEN_CACHE_TTL=7140

# 飞书消息发送超时（秒）
LARK_REQUEST_TIMEOUT=30

# 飞书消息发送重试次数
LARK_MAX_RETRIES=3

# ============================================
# 大模型配置
# ============================================

# LLM提供商: mock | openai | anthropic | azure | private
LLM_PROVIDER=mock

# LLM模型名称
LLM_MODEL_NAME=gpt-4

# LLM API密钥（生产环境必须使用真实密钥）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM API基础URL
LLM_API_BASE=https://api.openai.com/v1

# LLM默认温度（0-2）
LLM_TEMPERATURE=0.7

# LLM最大Token数
LLM_MAX_TOKENS=4096

# LLM请求超时（秒）
LLM_REQUEST_TIMEOUT=60

# LLM最大重试次数
LLM_MAX_RETRIES=3

# LLM Embedding模型名称
LLM_EMBEDDING_MODEL=text-embedding-3-small

# LLM Embedding维度（必须与模型匹配）
LLM_EMBEDDING_DIMENSION=1536

# ============================================
# 安全配置
# ============================================

# 启用输入验证
SECURITY_ENABLE_INPUT_VALIDATION=true

# 启用提示词注入防护
SECURITY_ENABLE_PROMPT_INJECTION_GUARD=true

# 启用数据脱敏
SECURITY_ENABLE_DATA_MASKING=true

# 启用内容合规检查
SECURITY_ENABLE_CONTENT_COMPLIANCE=true

# 启用跨项目访问拦截
SECURITY_ENABLE_PROJECT_ISOLATION=true

# 最大输入长度（字符）
SECURITY_MAX_INPUT_LENGTH=10000

# 敏感词列表文件路径
SECURITY_SENSITIVE_WORDS_FILE=./config/sensitive_words.txt

# JWT令牌过期时间（秒）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT刷新令牌过期时间（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# RAG检索配置
# ============================================

# 文档切片大小
RAG_CHUNK_SIZE=512

# 文档切片重叠大小
RAG_CHUNK_OVERLAP=50

# 检索Top-K数量
RAG_TOP_K=5

# 检索相似度阈值
RAG_SIMILARITY_THRESHOLD=0.7

# 启用检索重排
RAG_ENABLE_RERANK=true

# 重排模型名称
RAG_RERANK_MODEL=cross-encoder

# ============================================
# 审计日志配置
# ============================================

# 启用审计日志
AUDIT_ENABLE=true

# 审计日志存储路径
AUDIT_LOG_PATH=/var/log/pm_digital_employee/audit

# 审计日志保留天数（满足6个月监管要求）
AUDIT_RETENTION_DAYS=180

# 审计日志加密存储
AUDIT_ENABLE_ENCRYPTION=true

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# 日志格式: json | text
LOG_FORMAT=json

# 日志存储路径
LOG_FILE_PATH=/var/log/pm_digital_employee

# 日志文件最大大小（MB）
LOG_MAX_SIZE=100

# 日志文件最大数量
LOG_MAX_FILES=10

# 启用日志压缩
LOG_ENABLE_COMPRESSION=true

# ============================================
# 监控配置
# ============================================

# 启用Prometheus指标
ENABLE_METRICS=true

# Prometheus指标端口
METRICS_PORT=9090

# 启用健康检查详细指标
ENABLE_HEALTH_DETAILS=true

# ============================================
# 多Agent配置
# ============================================

# 启用多Agent能力
AGENT_ENABLE=true

# Agent最大执行步数
AGENT_MAX_STEPS=10

# Agent执行超时（秒）
AGENT_TIMEOUT=300

# Agent结果校验模式
AGENT_VALIDATE_MODE=strict

# ============================================
# Skill配置
# ============================================

# Skill自动注册目录
SKILL_AUTO_REGISTER_DIR=app/skills

# Skill执行超时（秒）
SKILL_EXECUTE_TIMEOUT=120

# Skill结果缓存时间（秒）
SKILL_RESULT_CACHE_TTL=300

# ============================================
# 会话与上下文配置
# ============================================

# 会话上下文缓存时间（秒）
SESSION_CONTEXT_TTL=28800

# 多轮对话状态过期时间（秒）
DIALOG_STATE_TTL=1800

# 最大多轮对话次数
MAX_DIALOG_ROUNDS=5

# ============================================
# 权限配置
# ============================================

# 权限缓存时间（秒）
PERMISSION_CACHE_TTL=3600

# 群绑定缓存时间（秒）
GROUP_BINDING_CACHE_TTL=86400

# 默认拒绝策略
PERMISSION_DEFAULT_DENY=true

# ============================================
# 第三方系统适配配置（Mock模式）
# ============================================

# 项目管理系统适配器: mock | real
PROJECT_SYSTEM_ADAPTER=mock

# 财务系统适配器: mock | real
FINANCE_SYSTEM_ADAPTER=mock

# DevOps系统适配器: mock | real
DEVOPS_SYSTEM_ADAPTER=mock

# 缺陷管理系统适配器: mock | real
DEFECT_SYSTEM_ADAPTER=mock

# OA审批系统适配器: mock | real
OA_SYSTEM_ADAPTER=mock

# ============================================
# 定时任务配置
# ============================================

# 启用每日进度检查
SCHEDULE_ENABLE_PROGRESS_CHECK=true

# 每日进度检查时间（cron表达式）
SCHEDULE_PROGRESS_CHECK_CRON=0 9 * * *

# 启用每日风险扫描
SCHEDULE_ENABLE_RISK_SCAN=true

# 每日风险扫描时间（cron表达式）
SCHEDULE_RISK_SCAN_CRON=*/30 * * * *

# 启用周报自动生成
SCHEDULE_ENABLE_WEEKLY_REPORT=true

# 周报自动生成时间（cron表达式）
SCHEDULE_WEEKLY_REPORT_CRON=0 17 * * 5

# ============================================
# 开发与测试配置
# ============================================

# 测试数据库URL
TEST_DATABASE_URL=postgresql+asyncpg://pm_user:pm_password_change_in_production@localhost:5432/pm_test

# 测试Redis URL
TEST_REDIS_URL=redis://:pm_redis_password_change_in_production@localhost:6379/2

# Mock LLM响应延迟（秒，用于测试）
MOCK_LLM_RESPONSE_DELAY=0.5

# 启用API文档
ENABLE_API_DOCS=true

# API文档路径
API_DOCS_PATH=/docs

# APIRedoc路径
API_REDOC_PATH=/redoc