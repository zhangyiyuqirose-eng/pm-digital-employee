# PM Digital Employee - 环境变量配置示例
# 项目经理数字员工系统 - 环境变量配置（开发环境）
# 飞书作为唯一用户交互入口

# ============================================
# 应用基础配置
# ============================================
APP_NAME=PM Digital Employee
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=dev_secret_key_change_in_production_32chars
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# ============================================
# PostgreSQL数据库配置
# ============================================
POSTGRES_USER=pm_user
POSTGRES_PASSWORD=pm_password_123
POSTGRES_DB=pm_digital_employee
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pm_user:pm_password_123@postgres:5432/pm_digital_employee
DATABASE_URL_SYNC=postgresql://pm_user:pm_password_123@postgres:5432/pm_digital_employee

# ============================================
# Redis缓存配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_123
REDIS_DB=0
REDIS_URL=redis://:redis_123@redis:6379/0

# ============================================
# RabbitMQ消息队列配置
# ============================================
RABBITMQ_USER=pm_rabbitmq
RABBITMQ_PASSWORD=rabbitmq_123
RABBITMQ_VHOST=/
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
CELERY_BROKER_URL=pyamqp://pm_rabbitmq:rabbitmq_123@localhost:5672//
CELERY_RESULT_BACKEND=redis://:redis_123@localhost:6379/1

# ============================================
# 飞书开放平台配置
# ============================================
LARK_APP_ID=cli_a1b2c3d4e5f6g7h8
LARK_APP_SECRET=your_lark_app_secret
LARK_ENCRYPT_KEY=your_encrypt_key
LARK_VERIFICATION_TOKEN=your_verification_token
LARK_APP_ROOT_DOMAIN=https://open.feishu.cn
LARK_BOT_NAME=PM Digital Employee

# ============================================
# 大模型配置
# ============================================
LLM_PROVIDER=mock
LLM_MODEL_NAME=gpt-4
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ============================================
# 安全配置
# ============================================
SECURITY_ENABLE_INPUT_VALIDATION=true
SECURITY_ENABLE_PROMPT_INJECTION_GUARD=true
SECURITY_ENABLE_DATA_MASKING=true
SECURITY_MAX_INPUT_LENGTH=10000

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# 监控配置
# ============================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# 开发配置
# ============================================
ENABLE_API_DOCS=true
API_DOCS_PATH=/docs
API_REDOC_PATH=/redoc

# ============================================
# 第三方系统适配配置（Mock模式）
# ============================================
PROJECT_SYSTEM_ADAPTER=mock
FINANCE_SYSTEM_ADAPTER=mock
DEVOPS_SYSTEM_ADAPTER=mock
DEFECT_SYSTEM_ADAPTER=mock
OA_SYSTEM_ADAPTER=mock